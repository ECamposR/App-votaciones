# Entorno: 'development' o 'production'
ENVIRONMENT=development

# Conexión a la Base de Datos (PostgreSQL async via asyncpg)
# En desarrollo (docker-compose.dev.yml), la base de datos se llama 'db'
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_password@db:5432/votaciones

# Seguridad y JWT
# IMPORTANTE: Cambiar JWT_SECRET por una cadena aleatoria segura en producción
JWT_SECRET=super_secret_cryptographic_key_replace_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Configuración de Servidor y Orígenes Permitidos
# Hosts permitidos para TrustedHostMiddleware (FastAPI)
ALLOWED_HOSTS=localhost,127.0.0.1,votaciones.local

# CORS (Orígenes permitidos, separados por comas)
# En desarrollo local el frontend de Vite corre usualmente en http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL (Usado por el contenedor oficial de Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=votaciones
